// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  FOUNDER
  ADMIN
}

enum FounderRank {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  STARTER
  PROMOTER
}

enum ReferralStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum ScopeMode {
  ROLE
  RANK
  OFFER
  UNILEVEL
}

enum RewardType {
  PERCENTAGE
  FLAT
}

enum RuleStatus {
  ACTIVE
  PAUSED
}

enum MarketingAssetsType {
  AUDIO 
  VIDEO 
  DESIGN
  PDF
  IMAGE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  avatarUrl String?
  role      UserRole @default(USER)
  isFounder Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  founder        Founder?
  referredBy     Referral? @relation("ReferredUser")
  refreshTokens  RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  notifications  Notification[]

  @@map("User")
}

model Founder {
  id             String      @id @default(uuid())
  userId         String      @unique
  founderCode    String?
  rank           FounderRank @default(STARTER)
  joinDate       DateTime    @default(now())
  totalEarnings  Float       @default(0)
  coins          Int         @default(0)
  lastClaimDate  DateTime?
  claimStreak    Int         @default(0)
  referralLink   String      @unique
  
  // Relations
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals    Referral[]
  payouts      PayoutRequest[]
  commissionEarnings CommissionEarning[]
  coinClaims    CoinClaim[]

  @@map("Founder")
}

model Referral {
  id             String         @id @default(uuid())
  founderId      String
  referredUserId String         @unique
  status         ReferralStatus @default(PENDING)
  joinedAt       DateTime       @default(now())
  
  // Relations
  founder      Founder @relation(fields: [founderId], references: [id], onDelete: Cascade)
  referredUser User    @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  commissionEarnings CommissionEarning[]

  @@map("Referral")
}

model FounderCode {
  id         String   @id @default(uuid())
  code       String   @unique
  isActive   Boolean  @default(true)
  maxUses    Int?
  usedCount  Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("FounderCode")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("RefreshToken")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("PasswordResetToken")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Notification")
}



model CommissionRule {
  id         String      @id @default(uuid())
  name       String
  scopeMode  ScopeMode
  role       UserRole?
  rank       FounderRank?
  offer      String?
  level      String?
  rewardType RewardType
  value      Float
  stackable  Boolean     @default(false)
  status     RuleStatus  @default(ACTIVE)
  note       String?
  
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  payouts    PayoutRequest[]
  commissionEarnings CommissionEarning[]

  @@map("CommissionRule")
}

enum PayoutStatus {
  PENDING
  APPROVED
  ON_HOLD
  PAID
}

model PayoutRequest {
  id           String       @id @default(uuid())
  founderId    String
  commissionRuleId String?
  amount       Float
  status       PayoutStatus @default(PENDING)
  notes        String?
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  founder      Founder      @relation(fields: [founderId], references: [id], onDelete: Cascade)
  commissionRule CommissionRule? @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)

  @@map("PayoutRequest")
}

model CommissionEarning {
  id               String    @id @default(uuid())
  founderId        String
  referralId       String?
  commissionRuleId String?
  amount           Float
  currency         String    @default("USD")
  createdAt        DateTime  @default(now())

  founder          Founder   @relation(fields: [founderId], references: [id], onDelete: Cascade)
  referral         Referral? @relation(fields: [referralId], references: [id], onDelete: SetNull)
  commissionRule   CommissionRule? @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)

  @@map("CommissionEarning")
}

model CoinClaim {
  id         String   @id @default(uuid())
  founderId  String
  amount     Int
  createdAt  DateTime @default(now())

  founder    Founder  @relation(fields: [founderId], references: [id], onDelete: Cascade)

  @@map("CoinClaim")
}

model ActivityLog {
  id        String   @id @default(uuid())
  type      String
  meta      String?
  createdAt DateTime @default(now())

  @@map("ActivityLog")
}


model MarketingAsset {
  id              String              @id @default(uuid())
  title           String
  type            MarketingAssetsType
  icon            String?
  formats         String[]
  description     String
  fileUrl         String
  thumbnailUrl    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("MarketingAsset")
}

model TrainingCourse {
  id              String   @id @default(uuid())
  title           String
  duration        String
  level           String
  description     String
  focus           String
  thumbnailUrl    String
  videoUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("TrainingCourse")
}


